#!/usr/bin/env bash
# Custodian regression guard — pre-push hook.
# Runs the same audit CI runs. Catches new findings before they hit GitHub.
#
# Install once per clone:
#   git config core.hooksPath .hooks
# Bypass intentionally: git push --no-verify
set -e

repo_root="$(git rev-parse --show-toplevel)"
workspace_root="$(cd "$repo_root/.." && pwd)"

# Discover the central private-name blocklist without hardcoding any
# private repo identity into this public repo.
if [ -z "${CUSTODIAN_PRIVATE_REPO_NAMES_FILE:-}" ]; then
    shopt -s nullglob
    for candidate in         "$workspace_root"/*/policy/private_repo_names.yaml         "$workspace_root"/*/policy/private_repo_names.yml         "$workspace_root"/*/policy/private_repo_names.json         "$workspace_root"/*/policy/private_repo_names.txt
    do
        if [ -f "$candidate" ]; then
            export CUSTODIAN_PRIVATE_REPO_NAMES_FILE="$candidate"
            break
        fi
    done
    shopt -u nullglob
fi

custodian_multi=""
if command -v custodian-multi >/dev/null 2>&1; then
    custodian_multi="$(command -v custodian-multi)"
fi

for candidate in     "$custodian_multi"     "$repo_root/.venv/bin/custodian-multi"     "$repo_root/.warehouse-venv/bin/custodian-multi"     "$workspace_root/Custodian/.venv/bin/custodian-multi"
do
    if [ -x "$candidate" ]; then
        custodian_multi="$candidate"
        break
    fi
done

if [ -z "$custodian_multi" ]; then
    echo "[custodian-pre-push] custodian-multi not found — skipping audit guard"
    echo "    install with: python -m pip install -e /home/dev/Documents/GitHub/Custodian"
    exit 0
fi

echo "[custodian-pre-push] running audit guard..."
"$custodian_multi" --repos "$repo_root" --fail-on-findings --no-color
